{
  "name": "time-poetry-particle-clock",
  "version": "1.0.0",
  "description": "An interactive Three.js particle clock made of Chinese time poetry glyphs.",
  "type": "commonjs",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
