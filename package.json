    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "threejs",
    "webgl",
    "particle-clock",
    "interactive-art",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "playwright": "^1.61.0",
    "three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
